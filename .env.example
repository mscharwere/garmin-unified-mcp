# garmin-unified-mcp credentials
# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
#
# GARMIN_USERS — JSON array of {id, email, password} objects, one per Garmin
# Connect account this MCP should serve. Each `id` becomes a valid `user`
# enum value on every tool. Single-line JSON; escape inner quotes if your
# shell needs it.
GARMIN_USERS=[{"id":"carlos","email":"","password":""},{"id":"carlitos","email":"","password":""},{"id":"daniel","email":"","password":""}]

# GARMIN_TOKEN_ROOT — base directory for per-user OAuth token caches.
# Per-user dirs created at ${GARMIN_TOKEN_ROOT}/${userId}/.
GARMIN_TOKEN_ROOT=C:\Users\mscha\.garmin-mcp-unified
